{
  "name": "test-project-sveltekit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:cf": "vite build && wrangler pages dev .svelte-kit/cloudflare",
